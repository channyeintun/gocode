    "silvery": "file:vendor/silvery-local",
    "marked": "^15.0.12",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  }
}

{
  "name": "chan-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "chan": "bin/chan.js"
  },
  "scripts": {
    "build": "bunx tsc",
    "start": "bun bin/chan.js",
    "dev": "bunx tsc --watch",
